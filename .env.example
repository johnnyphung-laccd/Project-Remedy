# =============================================================================
# LAMC ADA Document Remediation Pipeline - Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# These variables override any matching settings in config.yaml.

# -- API credentials --------------------------------------------------------
ZAI_API_KEY=your-api-key-here
ZAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# -- Crawl settings ---------------------------------------------------------
CRAWL_START_URL=https://www.lamission.edu/
CRAWL_MAX_DEPTH=10
CRAWL_MAX_PAGES=10000
CRAWL_RATE_LIMIT=2

# -- Processing settings ----------------------------------------------------
MAX_CONCURRENT_API_CALLS=5
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2

# -- Output paths -----------------------------------------------------------
OUTPUT_DIR=./output
LOG_DIR=./logs
DB_PATH=./pipeline.db

# -- Validation settings ----------------------------------------------------
VALIDATION_MAX_REMEDIATION_CYCLES=3
VALIDATION_FAIL_ON_SERIOUS=true
